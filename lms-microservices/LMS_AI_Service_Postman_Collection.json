{
  "info": {
    "name": "LMS AI Service",
    "_postman_id": "lms-ai-service-v2",
    "description": "Collection pour tester tous les endpoints du AI Service. Inclut l'authentification et le RAG.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "admin_token", "value": "", "type": "string" },
    { "key": "student_token", "value": "", "type": "string" },
    { "key": "lecturer_token", "value": "", "type": "string" },
    { "key": "module_admin_systemes", "value": "2", "type": "string" },
    { "key": "module_algo", "value": "3", "type": "string" },
    { "key": "module_reseaux", "value": "5", "type": "string" },
    { "key": "module_bdd", "value": "7", "type": "string" },
    { "key": "student_id", "value": "dmedoune", "type": "string" }
  ],
  "item": [
    {
      "name": "1. Authentification et Profil",
      "item": [
        {
          "name": "1.1 Login (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.token) {",
                  "    pm.collectionVariables.set('admin_token', jsonData.token);",
                  "    pm.collectionVariables.set('token', jsonData.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/user/auth/login", "host": ["{{base_url}}"], "path": ["api", "user", "auth", "login"] },
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"admin@lms.sn\",\n  \"password\": \"admin123\"\n}" }
          }
        },
        {
          "name": "1.2 Login (Student)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.token) {",
                  "    pm.collectionVariables.set('student_token', jsonData.token);",
                  "    pm.collectionVariables.set('token', jsonData.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/user/auth/login", "host": ["{{base_url}}"], "path": ["api", "user", "auth", "login"] },
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"dmedoune@ept.sn\",\n  \"password\": \"password123\"\n}" }
          }
        },
        {
          "name": "1.3 Login (Lecturer)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.token) {",
                  "    pm.collectionVariables.set('lecturer_token', jsonData.token);",
                  "    pm.collectionVariables.set('token', jsonData.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/user/auth/login", "host": ["{{base_url}}"], "path": ["api", "user", "auth", "login"] },
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"aaciss@ept.sn\",\n  \"password\": \"password123\"\n}" }
          }
        }
      ]
    },
    {
      "name": "2. Sante et Configuration",
      "item": [
        {
          "name": "2.1 Health Check - Services UP",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"prompt\": \"Réponds juste 'OK' sans rien d'autre.\"\n}" },
            "url": { "raw": "{{base_url}}/api/ai/chatbot/ask", "host": ["{{base_url}}"], "path": ["api", "ai", "chatbot", "ask"] }
          }
        }
      ]
    },
    {
      "name": "3. Chatbot - Mode General",
      "item": [
        {
          "name": "3.1 Question generale (sans module)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"prompt\": \"Qu'est-ce qu'une adresse IP et comment fonctionne le protocole TCP/IP ?\"\n}" },
            "url": { "raw": "{{base_url}}/api/ai/chatbot/ask", "host": ["{{base_url}}"], "path": ["api", "ai", "chatbot", "ask"] }
          }
        },
        {
          "name": "3.2 Question de code (Python/Algo)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"prompt\": \"Explique la différence entre une liste chaînée et un tableau avec un exemple de code en Python\"\n}" },
            "url": { "raw": "{{base_url}}/api/ai/chatbot/ask", "host": ["{{base_url}}"], "path": ["api", "ai", "chatbot", "ask"] }
          }
        },
        {
          "name": "3.3 Question courte et simple",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"prompt\": \"Qu'est-ce qu'une clé primaire en SQL ?\"\n}" },
            "url": { "raw": "{{base_url}}/api/ai/chatbot/ask", "host": ["{{base_url}}"], "path": ["api", "ai", "chatbot", "ask"] }
          }
        }
      ]
    },
    {
      "name": "4. Chatbot - Mode Focus (RAG par module)",
      "item": [
        {
          "name": "4.1 Focus Module - Admin Systemes",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"prompt\": \"Comment configurer un serveur SSH sur Linux ?\",\n  \"moduleId\": {{module_admin_systemes}}\n}" },
            "url": { "raw": "{{base_url}}/api/ai/chatbot/ask", "host": ["{{base_url}}"], "path": ["api", "ai", "chatbot", "ask"] }
          }
        },
        {
          "name": "4.2 Focus Module - Bases de Donnees (SQL)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"prompt\": \"Explique les différents types de JOIN en SQL avec des exemples\",\n  \"moduleId\": {{module_bdd}}\n}" },
            "url": { "raw": "{{base_url}}/api/ai/chatbot/ask", "host": ["{{base_url}}"], "path": ["api", "ai", "chatbot", "ask"] }
          }
        },
        {
          "name": "4.3 Focus Module - Reseaux (avec contexte)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"prompt\": \"Différence entre TCP et UDP\",\n  \"moduleId\": {{module_reseaux}},\n  \"context\": \"Niveau debutant DIC1\"\n}" },
            "url": { "raw": "{{base_url}}/api/ai/chatbot/ask", "host": ["{{base_url}}"], "path": ["api", "ai", "chatbot", "ask"] }
          }
        }
      ]
    },
    {
      "name": "5. Generation de Syllabus (Template)",
      "item": [
        {
          "name": "5.1 Syllabus - Admin Systemes",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{lecturer_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"prompt\": \"generate course template\",\n  \"moduleId\": {{module_admin_systemes}}\n}" },
            "url": { "raw": "{{base_url}}/api/ai/chatbot/generate-template", "host": ["{{base_url}}"], "path": ["api", "ai", "chatbot", "generate-template"] }
          }
        },
        {
          "name": "5.2 Syllabus - BDD (avec instructions)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{lecturer_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"prompt\": \"generate course template\",\n  \"moduleId\": {{module_bdd}},\n  \"context\": \"Emphasis on PostgreSQL and normalization.\"\n}" },
            "url": { "raw": "{{base_url}}/api/ai/chatbot/generate-template", "host": ["{{base_url}}"], "path": ["api", "ai", "chatbot", "generate-template"] }
          }
        },
        {
          "name": "5.3 Syllabus - Sans moduleId (fallback)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{lecturer_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"prompt\": \"generate course template\"\n}" },
            "url": { "raw": "{{base_url}}/api/ai/chatbot/generate-template", "host": ["{{base_url}}"], "path": ["api", "ai", "chatbot", "generate-template"] }
          }
        }
      ]
    },
    {
      "name": "6. Generation de Quiz IA",
      "item": [
        {
          "name": "6.1 Generer Quiz - Reseaux Informatiques",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{lecturer_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"prompt\": \"generate quiz\",\n  \"moduleId\": {{module_reseaux}}\n}" },
            "url": { "raw": "{{base_url}}/api/ai/chatbot/generate-quiz", "host": ["{{base_url}}"], "path": ["api", "ai", "chatbot", "generate-quiz"] }
          }
        },
        {
          "name": "6.2 Generer Quiz - Algo (avec contexte)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{lecturer_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"prompt\": \"generate quiz\",\n  \"moduleId\": {{module_algo}},\n  \"context\": \"Focus on sorting and complexity.\"\n}" },
            "url": { "raw": "{{base_url}}/api/ai/chatbot/generate-quiz", "host": ["{{base_url}}"], "path": ["api", "ai", "chatbot", "generate-quiz"] }
          }
        },
        {
          "name": "6.3 Generer Quiz - Sans module (fallback)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{lecturer_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"prompt\": \"generate quiz\",\n  \"context\": \"Quiz on OOP principles.\"\n}" },
            "url": { "raw": "{{base_url}}/api/ai/chatbot/generate-quiz", "host": ["{{base_url}}"], "path": ["api", "ai", "chatbot", "generate-quiz"] }
          }
        }
      ]
    },
    {
      "name": "7. Indexation RAG",
      "item": [
        {
          "name": "7.1 Indexer un support PDF (demarrage)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{lecturer_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/ai/chatbot/index-material?materialId=1&moduleId=2&fileUrl=sample.pdf",
              "host": ["{{base_url}}"],
              "path": ["api", "ai", "chatbot", "index-material"],
              "query": [
                { "key": "materialId", "value": "1" },
                { "key": "moduleId", "value": "2" },
                { "key": "fileUrl", "value": "sample.pdf" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "8. Remediation IA (Post-Quiz Rate)",
      "item": [
        {
          "name": "8.1 Remediation - 1 competence (Reseaux)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"studentId\": \"{{student_id}}\",\n  \"moduleId\": {{module_reseaux}},\n  \"quizResultId\": 46,\n  \"quizTitle\": \"Quiz - Réseaux Informatiques\",\n  \"wrongQuestions\": [\n    {\n      \"questionText\": \"Quel est le but du modèle OSI ?\",\n      \"competence\": \"Réseaux\",\n      \"justification\": \"Le modèle OSI standardise les communications réseau en 7 couches.\",\n      \"correctAnswer\": \"Standardiser les communications réseau en couches\"\n    }\n  ]\n}" },
            "url": { "raw": "{{base_url}}/api/ai/remediation/generate", "host": ["{{base_url}}"], "path": ["api", "ai", "remediation", "generate"] }
          }
        },
        {
          "name": "8.2 Remediation - Multi-competences",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"studentId\": \"{{student_id}}\",\n  \"moduleId\": {{module_algo}},\n  \"quizResultId\": 47,\n  \"quizTitle\": \"Quiz Test Adaptatif\",\n  \"wrongQuestions\": [\n    {\n      \"questionText\": \"Complexite tri a bulles ?\",\n      \"competence\": \"Algorithmique\",\n      \"justification\": \"O(n²) car double boucle.\",\n      \"correctAnswer\": \"O(n²)\"\n    }\n  ]\n}" },
            "url": { "raw": "{{base_url}}/api/ai/remediation/generate", "host": ["{{base_url}}"], "path": ["api", "ai", "remediation", "generate"] }
          }
        },
        {
          "name": "8.3 Remediation - Fallback General",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"studentId\": \"{{student_id}}\",\n  \"moduleId\": {{module_bdd}},\n  \"quizResultId\": 45,\n  \"wrongQuestions\": [\n    {\n      \"questionText\": \"DROP TABLE ?\",\n      \"justification\": \"Supprime une table.\",\n      \"correctAnswer\": \"DROP TABLE\"\n    }\n  ]\n}" },
            "url": { "raw": "{{base_url}}/api/ai/remediation/generate", "host": ["{{base_url}}"], "path": ["api", "ai", "remediation", "generate"] }
          }
        }
      ]
    }
  ]
}
