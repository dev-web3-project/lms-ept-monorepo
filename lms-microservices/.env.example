# ============================================================
# LMS EPT — Variables d'environnement locales (Exemple)
# Copiez ce fichier vers .env et modifiez les valeurs
# ============================================================

# --- PostgreSQL commun ---
DB_USERNAME=postgres
DB_PASSWORD=password

POSTGRES_USER=postgres
POSTGRES_PASSWORD=password

# --- URLs spécifiques par service (database-per-service) ---
USER_DB_URL=jdbc:postgresql://localhost:5432/user_db
COURSE_DB_URL=jdbc:postgresql://localhost:5432/course_db
UNIVERSITY_DB_URL=jdbc:postgresql://localhost:5432/university_db
ANNOUNCEMENT_DB_URL=jdbc:postgresql://localhost:5432/announcement_db
AI_DB_URL=jdbc:postgresql://localhost:5432/ai_db

# --- Eureka Discovery ---
EUREKA_URL=http://localhost:8761/eureka/

# --- JWT (user-service) ---
JWT_SECRET=your_jwt_secret_key_here_minimum_64_characters
JWT_EXPIRATION=86400000

# --- IA — Groq (LLM principal) ---
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# --- IA — Google Gemini (Embeddings RAG) ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Frontend (CORS) ---
FRONTEND_URL=http://localhost:3000

# --- File Storage ---
UPLOAD_DIR=./uploads