{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "LMS University Service",
    "description": "Collection exhaustive pour tester tous les endpoints du University Service. Couvre les Cycles, Départements et Classes. Le token admin est automatiquement sauvegardé après le login via le User Service.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentification",
      "item": [
        {
          "name": "1. Login (Admin) — via User Service",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.token) {",
                  "    pm.collectionVariables.set('admin_token', jsonData.token);",
                  "    pm.collectionVariables.set('token', jsonData.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/user/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "user", "auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin@lms.sn\",\n  \"password\": \"admin123\"\n}"
            }
          }
        }
      ]
    },
