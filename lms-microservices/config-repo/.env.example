# ============================================================
# LMS EPT — Template de variables d'environnement
# 1. Copier ce fichier : cp .env.example ../.env
# 2. Remplir les vraies valeurs
# 3. Ne JAMAIS commiter le fichier .env (déjà dans .gitignore)
# ============================================================

# --- Base de données PostgreSQL ---
DB_URL=jdbc:postgresql://localhost:5432/lmsdb
DB_USERNAME=VOTRE_USER_POSTGRES
DB_PASSWORD=VOTRE_MOT_DE_PASSE_POSTGRES

POSTGRES_USER=VOTRE_USER_POSTGRES
POSTGRES_PASSWORD=VOTRE_MOT_DE_PASSE_POSTGRES
POSTGRES_DB=lmsdb

# --- Eureka Discovery ---
EUREKA_URL=http://localhost:8761/eureka/

# --- JWT (générer un secret aléatoire en prod : openssl rand -hex 32) ---
JWT_SECRET=VOTRE_SECRET_JWT_HEX_64_CHARS
JWT_EXPIRATION=86400000

# --- IA — Groq (LLM principal, gratuit 14k req/jour) ---
# Créer un compte et obtenir une clé sur : https://console.groq.com
GROQ_API_KEY=gsk_VOTRE_CLE_GROQ
GROQ_MODEL=llama-3.3-70b-versatile

# --- IA — Google Gemini (Embeddings pour RAG) ---
# Obtenir une clé sur : https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSy_VOTRE_CLE_GEMINI

# --- Frontend URL (CORS) ---
FRONTEND_URL=http://localhost:3000

# --- Config Server (optionnel) ---
# Laisser vide pour utiliser la détection automatique
# CONFIG_REPO_PATH=/chemin/absolu/vers/lms-microservices/config-repo
